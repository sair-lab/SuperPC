echo "SLURMTMPDIR="$SLURMTMPDIR

echo "working directory = "$SLURM_SUBMIT_DIR


# module use /projects/academic/cwx/modulefiles
# module load python/my-python-3
source ~/.bashrc
conda activate supermap

