ulimit -s unlimited

which python
which pytest

nvidia-smi


cat simple_attention_pointNet2_addition_a100.script


python train_ae.py --run_name 'Simple-attention-additionSkip-TwoBranch-PointNet2' --project_name 'Super-Map-Project-SmallDataset'


